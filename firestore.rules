rules_version = '2';

// ═══════════════════════════════════════════════════════════════════════════
// FIRESTORE SECURITY RULES — Bro App
// ═══════════════════════════════════════════════════════════════════════════
// Deploy: firebase deploy --only firestore:rules
//
// Principles:
//   1. Users can only read/write their own private data
//   2. Bro connections require both users to exist
//   3. BroCoin wallets are private (owner-only read)
//   4. Public ledger is read-only for all authenticated users
//   5. Treasury is read-only for clients (written by server/Cloud Functions)

service cloud.firestore {
  match /databases/{database}/documents {

    // ── User Profiles ──────────────────────────────────────────────────
    // Users can read any profile (for bro lists, recommendations)
    // Users can only write their own profile
    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && request.auth.uid == userId;
      // Never allow delete (account deletion handled by admin/Cloud Function)
      allow delete: if false;
    }

    // ── Bro Connections ────────────────────────────────────────────────
    // Both users in the connection can read it
    // Only authenticated users can create connections (via Cloud Function ideally)
    match /bros/{connectionId} {
      allow read: if request.auth != null
        && request.auth.uid in resource.data.users;
      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.users;
      allow update: if request.auth != null
        && request.auth.uid in resource.data.users;
      allow delete: if false;
    }

    // ── Bro Requests ───────────────────────────────────────────────────
    // Sender and receiver can read their own requests
    match /bro_requests/{requestId} {
      allow read: if request.auth != null
        && (request.auth.uid == resource.data.from
            || request.auth.uid == resource.data.to);
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.from;
      allow update: if request.auth != null
        && request.auth.uid == resource.data.to;
      allow delete: if request.auth != null
        && (request.auth.uid == resource.data.from
            || request.auth.uid == resource.data.to);
    }

    // ── Transactions ───────────────────────────────────────────────────
    // Users can read their own transactions
    // Transactions are created by the sender
    match /transactions/{txId} {
      allow read: if request.auth != null
        && (request.auth.uid == resource.data.uid
            || request.auth.uid == resource.data.fromUid
            || request.auth.uid == resource.data.toUid);
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    // ── BroCoin Wallets (PRIVATE) ──────────────────────────────────────
    // ONLY the owner can read their wallet balance
    // Writes should ideally come from Cloud Functions only
    match /brocoin_wallets/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ── BroCoin Public Ledger ──────────────────────────────────────────
    // All authenticated users can read (it's anonymized)
    // Only server/Cloud Functions should write
    match /brocoin_ledger/{entryId} {
      allow read: if request.auth != null;
      // Allow write from authenticated users for now (move to Cloud Functions in prod)
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    // ── Treasury (Global State) ────────────────────────────────────────
    // All authenticated users can read treasury stats
    // Writes should be Cloud Functions only (allowing auth'd for demo)
    match /treasury/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ── Notifications ──────────────────────────────────────────────────
    match /notifications/{notifId} {
      allow read: if request.auth != null
        && request.auth.uid == resource.data.toUid;
      allow create: if request.auth != null;
      allow update: if request.auth != null
        && request.auth.uid == resource.data.toUid;
      allow delete: if false;
    }

    // ── Default: deny everything else ──────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
